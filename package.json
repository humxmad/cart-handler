{
  "name": "cart-handler",
  "version": "1.0.0",
  "description": "Framework-agnostic shopping cart state with subscriptions, totals, and optional persistence.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "check": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cart",
    "ecommerce",
    "typescript",
    "framework-agnostic"
  ],
  "author": "",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/humxmad/cart-handler.git"
  },
  "bugs": {
    "url": "https://github.com/humxmad/cart-handler/issues"
  },
  "homepage": "https://github.com/humxmad/cart-handler#readme",
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
